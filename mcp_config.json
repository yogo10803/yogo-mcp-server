{
	"servers": {
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"playwright": {
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"type": "stdio",
			"alwaysAllow": [
				"browser_handle_dialog",
				"browser_close",
				"browser_resize",
				"browser_console_messages",
				"browser_evaluate",
				"browser_file_upload",
				"browser_fill_form",
				"browser_install",
				"browser_press_key",
				"browser_type",
				"browser_navigate",
				"browser_navigate_back",
				"browser_network_requests",
				"browser_take_screenshot",
				"browser_snapshot",
				"browser_click",
				"browser_hover",
				"browser_drag",
				"browser_select_option",
				"browser_tabs",
				"browser_wait_for"
			]
		}
	},
	"inputs": []
}
